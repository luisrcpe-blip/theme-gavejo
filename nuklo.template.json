{
  "id": "theme-gavejo",
  "name": "Theme Gavejo",
  "mode": "capture",
  "contractVersion": "capture@1.0.0",
  "templateVersion": "2.1.6",
  "description": "Theme CAPTURE completo para Maderas Gavejo con home, contacto, blog, paginas internas, captacion de leads por postMessage y narrativa tecnica para proyectos en madera.",
  "repository": "https://github.com/luisrcpe-blip/theme-gavejo",
  "sourceBranch": "main",
  "entry": "/",
  "renderer": "remote-static-app",
  "appUrl": "https://luisrcpe-blip.github.io/theme-gavejo/",
  "previewUrl": "https://gavejo.nuklo.cloud",
  "surfaces": [
    "LEAD_LANDING",
    "CONTENT_PAGE"
  ],
  "capabilities": [
    "tenant",
    "branding",
    "media",
    "tracking",
    "leadLanding",
    "leadForm",
    "multiPageTheme",
    "contentPage"
  ],
  "forbidden": [
    "catalog",
    "product",
    "collection",
    "cart",
    "checkout",
    "orders",
    "coupons",
    "reviews",
    "commerceLanding"
  ],
  "requiredTenantSettings": [
    "domain",
    "mode=capture",
    "active=true",
    "landing.active=true"
  ],
  "requiredEnvironment": [],
  "leadTransport": "postMessage",
  "leadSubmitMessage": "nuklo-template:submit-lead",
  "leadResultMessage": "nuklo-template:lead-result",
